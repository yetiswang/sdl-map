---
import UnifiedLayout from '../../layouts/UnifiedLayout.astro';
import data from '../../data/sdl_data.json';
import uiAll from '../../i18n/ui.json';
import { entityName, entityOrg } from '../../utils/i18n';

const lang = 'zh';
const ui = uiAll[lang];
const prefix = lang === 'en' ? '/' : `/${lang}/`;

const stages = ['operational','prototype','concept'] as const;
const stageLabels = { operational: ui.stageOperational, prototype: ui.stagePrototype, concept: ui.stageConcept };
const tierColors = { national:'var(--c-national)', academic:'var(--c-academic)', commercial:'var(--c-commercial)', labos:'var(--c-labos)' };

const grouped = stages.map(s => ({ stage: s, label: stageLabels[s], items: data.filter(d=>d.maturity===s) })).filter(g => g.items.length > 0);
---

<UnifiedLayout title={`${ui.timeline} · ${ui.brandH1}`} lang={lang} activeView="timeline">
  <main class="tl-main" data-pagefind-body>
    <div class="tl-rail">
      <div class="tl-line"></div>
      {grouped.map(g => (
        <div class="tl-stage">
          <div class="tl-dot"></div>
          <h2 class="tl-h2">{g.label}</h2>
          <div class="tl-stage-list">
            {g.items.map(e => (
              <a href={`${prefix}entry/${e.id}/`} class="tl-card">
                <span class="tl-flag">{e.flag}</span><span class="tl-tierdot" style={`background:${tierColors[e.tier]};`}></span>
                <div class="tl-body">
                  <div class="tl-name">{entityName(e.id, e.name, lang)}</div>
                  <div class="tl-meta">{entityOrg(e.id, e.org, lang)} · {e.domain}</div>
                </div>
                {e.investLabel && <div class="tl-invest">{e.investLabel}</div>}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
  <style is:global>
    .tl-main { max-width:800px; margin:0 auto; padding:24px 28px; box-sizing:border-box; }
    .tl-rail { position:relative; padding-left:24px; }
    .tl-line { position:absolute; left:6px; top:8px; bottom:8px; width:2px; background:var(--rule); }
    .tl-stage { position:relative; margin-bottom:32px; }
    .tl-dot { position:absolute; left:-24px; top:4px; width:14px; height:14px; border-radius:50%; background:var(--bg-3); border:2px solid var(--ink-3); }
    .tl-h2 { font-size:16px; font-weight:600; margin:0 0 12px; color:var(--ink-2); }
    .tl-stage-list { display:flex; flex-direction:column; gap:8px; }
    .tl-card { display:flex; align-items:center; gap:12px; padding:10px 14px; background:var(--bg-2); border:1px solid var(--rule); border-radius:8px; color:inherit; min-width:0; }
    .tl-flag { font-size:18px; flex-shrink:0; }
    .tl-tierdot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .tl-body { flex:1; min-width:0; overflow:hidden; }
    .tl-name { font-weight:600; font-size:14px; overflow-wrap:anywhere; }
    .tl-meta { font-size:11px; color:var(--ink-3); overflow-wrap:anywhere; }
    .tl-invest { font-size:10px; color:var(--ink-3); font-family:var(--font-mono); white-space:nowrap; flex-shrink:0; }
    @media (max-width: 600px) {
      .tl-main { padding: 16px 12px; }
      .tl-rail { padding-left: 18px; }
      .tl-dot { left:-18px; width:11px; height:11px; }
      .tl-line { left:4px; }
      .tl-card { padding:9px 11px; gap:8px; flex-wrap:wrap; }
      .tl-invest { width:100%; padding-left:30px; }
    }
  </style>
</UnifiedLayout>
