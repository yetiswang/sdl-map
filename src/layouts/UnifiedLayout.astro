---
import uiAll from '../i18n/ui.json';
import countries from '../i18n/countries.json';
import chinaNames from '../i18n/china-names.json';
import data from '../data/sdl_data.json';

export interface Props {
  title: string;
  description?: string;
  lang: string;
  ogImage?: string;
  activeView?: 'map' | 'list' | 'timeline' | 'watch';
}

const {
  title, description = 'A curated interactive map of Self-Driving Laboratories worldwide.',
  lang = 'en', ogImage, activeView = 'map',
} = Astro.props;

const siteUrl = 'https://sdl-map.discoverylabs.nl';
const ui = (uiAll as any)[lang] || (uiAll as any)['en']; // fallback: zh→zh-Hans handled via lookup
const prefix = lang === 'en' ? '/' : `/${lang}/`;

// Dynamic stats computed at build time from sdl_data.json.
const statsTotal = (data as any[]).length;
const statsCountries = new Set((data as any[]).map((d) => d.country)).size;
const statsOperational = (data as any[]).filter(
  (d) => d.maturity === 'operational' || d.maturity === 'industrial'
).length;

// Simplified→Traditional dictionary, built ONCE at build time (was reconstructed
// on every /zh/ page load from three sources). Single source = ui.json +
// countries.json + china-names.json; the finished map is injected into the
// client, which only walks the DOM and substitutes. No runtime dict building.
const hansToHant: Record<string, string> = {};
function addDict(hans: any, hant: any) {
  if (!hans || !hant) return;
  for (const k of Object.keys(hans)) {
    const a = hans[k], b = hant[k];
    if (typeof a === 'string' && typeof b === 'string' && a !== b) hansToHant[a] = b;
  }
}
addDict((uiAll as any).zh, (uiAll as any)['zh-Hant']);
addDict((countries as any)['zh-Hans'], (countries as any)['zh-Hant']);
for (const id of Object.keys(chinaNames as any)) {
  const c = (chinaNames as any)[id];
  if (c && c['zh-Hans'] && c['zh-Hant']) {
    const h = c['zh-Hans'], t = c['zh-Hant'];
    if (h.name && t.name && h.name !== t.name) hansToHant[h.name] = t.name;
    if (h.org && t.org && h.org !== t.org) hansToHant[h.org] = t.org;
  }
}

// Languages in the switcher. Simplified and Traditional Chinese are shown as
// separate top-level buttons (per Yuyang's 18:58 spec: 簡繁中文雙版可選).
// `script` is used to build the iframe URL on /zh/ pages.
const langs = [
  { code: 'en',  label: 'EN', script: null },
  { code: 'zh', label: '简', script: 'Hans' },
  { code: 'zh', label: '繁', script: 'Hant' },
  { code: 'ja',  label: '日', script: null },
  { code: 'ko',  label: '한', script: null },
];

// Build alternative URL for a different language. For zh, both Hans and Hant
// route to /zh/* and toggle via a localStorage flag honoured on first paint.
function altUrl(toLang: string, script?: string | null): string {
  let path = Astro.url.pathname;
  path = path.replace(/^\/(en|zh|ja|ko)(\/|$)/, '/');
  if (path === '') path = '/';
  const base = toLang === 'en' ? path : `/${toLang}${path}`;
  if (toLang === 'zh' && script) return `${base}?script=${script}`;
  return base;
}
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hans' : lang} data-theme="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/png" href="/sdl_favicon.png">
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={siteUrl + Astro.url.pathname} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- Self-hosted fonts + shared design tokens (no third-party CDN). -->
<link rel="stylesheet" href="/tokens.css">
<link rel="stylesheet" href="/fonts.css">

<!-- Apply theme + ZH script preference BEFORE the iframe starts loading.
     localStorage is shared cross-frame, so writing here (synchronously, in
     <head>) means the iframe's own init reads consistent values regardless
     of what the iframe URL's built-in `?script=Hans` default says. -->
<script is:inline>
  (function(){
    try {
      var saved = localStorage.getItem('sdl-map-theme');
      var theme = (saved === 'light' || saved === 'dark') ? saved : 'dark';
      document.documentElement.setAttribute('data-theme', theme);
      if (saved !== theme) localStorage.setItem('sdl-map-theme', theme);

      // ZH script: URL param wins, otherwise leave whatever's already saved.
      var params = new URLSearchParams(window.location.search);
      var urlScript = params.get('script');
      if (urlScript === 'Hans' || urlScript === 'Hant') {
        localStorage.setItem('sdl-zh-script', urlScript);
      }
    } catch(e) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>

<style is:global>
/* design tokens now in /tokens.css (shared with the iframe map) */
html, body{ margin:0; padding:0; background:var(--bg); color:var(--ink); font-family:var(--font-sans); }
/* Use 100svh (small viewport height — the visible area when the mobile URL
   bar is shown) instead of 100vh (the largest area when the URL bar is
   hidden). With 100vh, body extends below the visible viewport on mobile
   and users have to scroll to see the footer. The 100vh line is the
   pre-svh fallback for older browsers. */
body{ min-height:100vh; min-height:100svh; -webkit-font-smoothing:antialiased; display:flex; flex-direction:column; }
/* Same viewport-fit treatment for the iframe-driven map page: header +
   iframe + footer add to exactly one visible viewport, no scroll needed. */
@supports (height: 100dvh) {
  body { min-height: 100dvh; }
}
main{ flex:1; }
a{ color:inherit; text-decoration:none; }

/* View nav pills */
.view-nav a { padding:6px 12px; border-radius:6px; font-size:14px; font-weight:500; color:var(--ink-2); text-decoration:none; transition:background .15s,color .15s; }
.view-nav a:hover { background:var(--bg-3); color:var(--ink); }
.view-nav a.active { background:var(--bg-3); color:var(--ink); }

/* Theme toggle */
.theme-toggle-btn { appearance:none; background:var(--bg-2); color:var(--ink); border:1px solid var(--rule); border-radius:8px; width:36px; height:36px; padding:0; display:inline-flex; align-items:center; justify-content:center; cursor:pointer; transition:border-color .15s,background .15s; flex-shrink:0; }
.theme-toggle-btn:hover { border-color:var(--ink-3); background:var(--bg-3); }
.theme-toggle-btn svg { width:18px; height:18px; }
/* `data-theme` lives on <html>, not <body>. Use :root so the icon swap actually fires. */
:root:not([data-theme="light"]) .theme-toggle-btn .ico-sun { display:none; }
:root[data-theme="light"] .theme-toggle-btn .ico-moon { display:none; }

/* Lang switcher */
.lang-btn { font-family:var(--font-mono); font-size:12px; font-weight:600; color:var(--ink-2); background:transparent; border:1px solid var(--rule); border-radius:6px; padding:4px 8px; cursor:pointer; transition:color .15s,background .15s; text-decoration:none; line-height:1.4; }
.lang-btn:hover, .lang-btn.active { color:var(--ink); background:var(--bg-3); border-color:var(--ink-3); }
.lang-switcher { position:relative; display:flex; gap:4px; align-items:center; }

/* Inline stat chips (right of view nav, before lang switcher). Replaces the
   separate stats-bar row — same info, no extra vertical space. */
.header-stats { display:flex; align-items:baseline; gap:14px; font-family:var(--font-mono); font-size:9.5px; color:var(--ink-3); letter-spacing:0.16em; text-transform:uppercase; white-space:nowrap; }
.header-stats span { display:inline-flex; align-items:baseline; gap:5px; }
.header-stats strong { color:var(--ink); font-weight:500; font-size:14px; letter-spacing:0; font-variant-numeric:tabular-nums; }

/* Nav cluster default (desktop) layout — kept here, NOT inline, so the
   mobile media query below can actually override it. Inline display:flex
   would beat any media query. */
.nav-cluster { display:flex; align-items:center; gap:14px; flex-shrink:0; flex-wrap:wrap; }

/* === Mobile-first compactness === */
.nav-hamburger {
  display:none; background:var(--bg-2); border:1px solid var(--rule); border-radius:8px;
  width:36px; height:36px; padding:0; align-items:center; justify-content:center;
  cursor:pointer; color:var(--ink); flex-shrink:0;
}
.nav-hamburger svg { width:20px; height:20px; }
/* Intermediate viewports (tablet / narrow desktop): hide stat chips first to
   buy room for nav + lang switcher + theme. */
@media (max-width: 1100px) {
  .header-stats { display:none !important; }
}

/* Below ~1024px the header has too many items (nav, 5 lang buttons, theme)
   to fit cleanly without squeezing. Collapse everything except brand into a
   hamburger drawer. */
@media (max-width: 1024px) {
  .site-header { padding:10px 14px 10px !important; gap:10px !important; flex-wrap:nowrap !important; align-items:center !important; }
  .site-header .brand-eyebrow { display:none !important; }
  .site-header .brand-h1 { font-size:18px !important; }
  .site-header .brand-h1-dim { display:none !important; }
  .site-header .tue-logo img { height:28px !important; }
  .site-header .nav-cluster { display:none; }
  .site-header .nav-cluster.open {
    display:flex; flex-direction:column; align-items:stretch; gap:10px;
    position:fixed; top:54px; right:8px; padding:14px;
    background:var(--bg-2); border:1px solid var(--rule); border-radius:10px;
    box-shadow:0 8px 28px oklch(0 0 0 / 0.30); min-width:200px;
    z-index:200;
  }
  .site-header .nav-cluster .view-nav { display:flex; flex-direction:column; gap:4px; }
  .site-header .nav-cluster .view-nav a { padding:8px 12px; }
  .site-header .nav-cluster .header-stats {
    display:flex !important; flex-direction:column; gap:6px;
    padding:8px 0; border-top:1px solid var(--rule); border-bottom:1px solid var(--rule);
  }
  .site-header .nav-cluster .lang-switcher { flex-wrap:wrap; padding:4px 0; }
  .site-header .nav-cluster .theme-toggle-btn { align-self:flex-start; }
  /* The thin vertical dividers between cluster groups are noise in the column layout */
  .site-header .nav-cluster > span[style*="width:1px"] { display:none; }
  .nav-hamburger { display:inline-flex; }
}
@media (max-width: 480px) {
  .site-header .brand-h1 { font-size:15px !important; }
  .site-header .tue-logo img { height:24px !important; }
}
</style>

<!-- Pagefind -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
</head>
<body>
  <!-- ===== HEADER ===== -->
  <header class="site-header" style="position:relative;z-index:60;background:var(--bg);display:flex;align-items:flex-end;justify-content:space-between;padding:18px 28px 14px;border-bottom:1px solid var(--rule);gap:40px;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:20px;min-width:0;">
      <a href="https://www.tue.nl/" target="_blank" rel="noopener" aria-label="TU Eindhoven" class="tue-logo" style="display:flex;align-items:center;flex-shrink:0;">
        <img src="/img/tue-logo.png" alt="TU Eindhoven" style="height:36px;width:auto;display:block;">
      </a>
      <div style="min-width:0;">
        <div class="brand-eyebrow" style="font-family:var(--font-mono);font-size:10px;color:var(--ink-3);letter-spacing:0.22em;text-transform:uppercase;margin-bottom:4px;">{ui.brandEyebrow}</div>
        <h1 class="brand-h1" style="font-family:var(--font-sans);font-weight:600;font-size:24px;letter-spacing:-0.01em;margin:0;color:var(--ink);line-height:1.2;">
          <a href={prefix}>{ui.brandH1}</a> <span class="brand-h1-dim" style="color:var(--ink-3);font-weight:400;">{ui.brandDim}</span>
        </h1>
      </div>
    </div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="nav-cluster" id="nav-cluster">
      <!-- View nav -->
      <nav class="view-nav" style="display:flex;align-items:center;gap:4px;">
        <a href={`${prefix}`} class={activeView==='map'?'active':''}>{ui.map}</a>
        <a href={`${prefix}list/`} class={activeView==='list'?'active':''}>{ui.list}</a>
        <a href={`${prefix}timeline/`} class={activeView==='timeline'?'active':''}>{ui.timeline}</a>
        <a href={`${prefix}watch/`} class={activeView==='watch'?'active':''}>{ui.watch}</a>
      </nav>
      <span style="width:1px;height:20px;background:var(--rule);"></span>
      <!-- Stats chips (replace the old stats-bar row) -->
      <div class="header-stats" aria-label="Counts">
        <span><strong>{statsTotal}</strong>{ui.initiatives}</span>
        <span><strong>{statsCountries}</strong>{ui.countries}</span>
        <span><strong>{statsOperational}</strong>{ui.operational}</span>
      </div>
      <span style="width:1px;height:20px;background:var(--rule);"></span>
      <!-- Language switcher: en · 简 · 繁 · 日 · 한, current always greyed out. -->
      <div class="lang-switcher">
        {langs.map(l => {
          const isCurrent = l.code === lang && (
            l.code !== 'zh' ||
            (l.script === 'Hant' ? false : true) // simplified is default on /zh/
          );
          return (
            <a
              href={altUrl(l.code, l.script)}
              class={`lang-btn${isCurrent ? ' active' : ''}`}
              title={l.label}
              data-lang={l.code}
              data-script={l.script || ''}
            >{l.label}</a>
          );
        })}
      </div>
      <!-- Theme toggle -->
      <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
        <svg class="ico-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="ico-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      </button>
    </div>
  </header>

  <!-- ===== MAIN CONTENT (header sits directly above the map — no stats row) ===== -->
  <div style="flex:1;min-height:0;display:flex;flex-direction:column;">
  <slot />
  </div>

  <!-- ===== FOOTER ===== -->
  <footer style="position:relative;z-index:60;background:var(--bg);padding:14px 28px;border-top:1px solid var(--rule);font-family:var(--font-mono);font-size:10.5px;color:var(--ink-3);letter-spacing:0.12em;">
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:center;text-align:center;">
      <span><a href="https://discoverylabs.nl" target="_blank" rel="noopener" style="color:var(--ink-2);border-bottom:1px dotted var(--ink-3);">{ui.footerDlnl}</a> · {ui.footerLandscape}</span>
      <span style="opacity:0.5;">·</span>
      <span>{ui.footerPart} <a href="https://tue-flagship-advanced-materials.nl" target="_blank" rel="noopener" style="color:var(--ink-2);border-bottom:1px dotted var(--ink-3);">{ui.footerFlagship}</a></span>
      <span style="opacity:0.5;">·</span>
      <span>{ui.footerBy} <a href="https://yuyang.nl" target="_blank" rel="noopener" style="color:var(--ink-2);border-bottom:1px dotted var(--ink-3);">{ui.footerAuthor}</a></span>
    </div>
  </footer>

  <!-- Theme toggle wiring + ZH script preference (theme is pre-applied in head) -->
  <script is:inline define:vars={{
    pageLang: lang,
    hansToHant,
  }}>
    (function(){
      function applyTheme(t){
        document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
      }
      function wireTheme(){
        var btn = document.getElementById('theme-toggle');
        if (!btn) { setTimeout(wireTheme, 100); return; }
        btn.addEventListener('click', function(e){
          e.stopPropagation();
          var cur = document.documentElement.getAttribute('data-theme');
          var next = cur === 'light' ? 'dark' : 'light';
          applyTheme(next);
          try { localStorage.setItem('sdl-map-theme', next); } catch(e){}
          // Tell the iframe via THREE channels — whichever lands first wins,
          // later ones are idempotent:
          //   - direct __sdlApplyTheme() call when the iframe is already booted
          //   - postMessage which delivers even if iframe is mid-async work
          //   - the storage write above wakes the iframe on tab refocus too
          var iframe = document.getElementById('sdl-iframe');
          if (iframe && iframe.contentWindow) {
            try {
              if (typeof iframe.contentWindow.__sdlApplyTheme === 'function') {
                iframe.contentWindow.__sdlApplyTheme(next);
              } else if (iframe.contentDocument) {
                var doc = iframe.contentDocument;
                if (next === 'light') doc.documentElement.setAttribute('data-theme', 'light');
                else doc.documentElement.removeAttribute('data-theme');
              }
              iframe.contentWindow.postMessage({ type: 'sdl-theme', theme: next }, '*');
            } catch(err){}
          }
        });
      }
      wireTheme();

      // === Mobile hamburger toggle ===
      function wireHamburger(){
        var btn = document.getElementById('nav-hamburger');
        var cluster = document.getElementById('nav-cluster');
        if (!btn || !cluster) { setTimeout(wireHamburger, 100); return; }
        btn.addEventListener('click', function(e){
          e.stopPropagation();
          var open = cluster.classList.toggle('open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        // Close on outside click
        document.addEventListener('click', function(e){
          if (!cluster.contains(e.target) && !btn.contains(e.target)) {
            cluster.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      }
      wireHamburger();

      // === ZH script (简⇄繁) — only relevant when pageLang === 'zh' ===
      if (pageLang === 'zh') {
        var params = new URLSearchParams(window.location.search);
        var urlScript = params.get('script');
        var savedScript = null;
        try { savedScript = localStorage.getItem('sdl-zh-script'); } catch(e){}
        var script = urlScript || savedScript || 'Hans';
        if (urlScript) { try { localStorage.setItem('sdl-zh-script', urlScript); } catch(e){} }
        document.documentElement.setAttribute('lang', script === 'Hant' ? 'zh-Hant' : 'zh-Hans');

        // hansToHant is built once at BUILD time (see frontmatter) and injected
        // above via define:vars. The client only walks the DOM and substitutes.

        function swapToHant() {
          if (script !== 'Hant') return;
          var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null);
          var node;
          while ((node = walker.nextNode())) {
            var s = node.textContent;
            if (!s) continue;
            // Whole-string match first (common case for labels like "项目")
            if (hansToHant[s]) { node.textContent = hansToHant[s]; continue; }
            // Substring replace for longer sentences (e.g. footer)
            var changed = false, out = s;
            Object.keys(hansToHant).forEach(function (k) {
              if (out.indexOf(k) !== -1) {
                out = out.split(k).join(hansToHant[k]);
                changed = true;
              }
            });
            if (changed) node.textContent = out;
          }
        }

        // Run after initial render + after any client-side updates
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', swapToHant);
        } else {
          swapToHant();
        }

        // No iframe src swap needed: localStorage is shared cross-frame and
        // the head script has already written `sdl-zh-script`. The iframe's
        // own map-i18n.js reads it before applying labels.
      }
    })();
  </script>
</body>
</html>
